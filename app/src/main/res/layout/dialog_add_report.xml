<?xml version="1.0" encoding="utf-8"?>
<!-- dialog_add_report.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- ✅ مجموعة CheckBox بدل Spinner -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="اختر أنواع النفايات:"
        android:textStyle="bold"
        android:textSize="16sp"
        android:paddingBottom="8dp"/>

    <LinearLayout
        android:id="@+id/checkboxContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="@drawable/shape_feilds"/>

    <Space
        android:layout_width="match_parent"
        android:layout_height="20dp"/>

    <!-- ✅ reCAPTCHA كما هو -->
    <LinearLayout
        android:id="@+id/recaptcha_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="@drawable/recaptcha_background">

        <CheckBox
            android:id="@+id/recaptcha_checkbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:minWidth="0dp"
            android:minHeight="0dp"/>

        <ProgressBar
            android:id="@+id/recaptcha_progressbar"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:visibility="gone"/>

        <ImageView
            android:id="@+id/error_ic"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:visibility="gone"
            android:src="@drawable/ic_error"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="I'm not a robot"
            android:textColor="@android:color/black"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:textSize="16sp"/>

        <ImageView
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:src="@drawable/ic_recaptcha"
            android:contentDescription="reCAPTCHA logo" />

    </LinearLayout>

    <Space
        android:layout_width="match_parent"
        android:layout_height="20dp"/>
</LinearLayout>
